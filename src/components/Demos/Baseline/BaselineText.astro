---
import "./baseline.css";
---

<div class="demo baseline-demo">
  <div class="baseline-demo__pair">
    <div>
      <p class="baseline-demo__label">Natural line height — drifts off the grid</p>
      <h2 class="baseline-demo__heading baseline-demo__heading--natural">
        A heading that ignores the grid
      </h2>
    </div>
    <div>
      <p class="baseline-demo__label">Snapped with round() — lands on a line</p>
      <h2 class="baseline-demo__heading baseline-demo__heading--snapped">
        A heading that lands on the grid
      </h2>
    </div>
  </div>
</div>
