---
const endpoint = "/.netlify/functions/spotify-latest";
---

<article class="spotify-latest" data-endpoint={endpoint}>
  <p class="spotify-latest__status color-meta" data-status>
    Loading latest Spotify track…
  </p>

  <a
    class="spotify-latest__content"
    href="#"
    hidden
    rel="noopener noreferrer"
    target="_blank"
    data-track
  >
    <img
      class="spotify-latest__artwork"
      src=""
      alt=""
      hidden
      width="70"
      height="70"
      loading="lazy"
      decoding="async"
      data-artwork
    />

    <div class="flow-2xs">
      <h3 class="spotify-latest__title" data-title></h3>
      <p class="spotify-latest__meta color-meta" data-meta></p>
    </div>
  </a>
</article>

<script>
  const components = document.querySelectorAll(
    ".spotify-latest[data-endpoint]",
  );

  function formatPlayedAt(playedAt) {
    if (!playedAt) {
      return "Recently played";
    }

    const date = new Date(playedAt);
    if (Number.isNaN(date.getTime())) {
      return "Recently played";
    }

    return `Last played ${date.toLocaleString()}`;
  }

  async function hydrateSpotify(component) {
    const endpoint = component.getAttribute("data-endpoint");
    const statusNode = component.querySelector("[data-status]");
    const trackNode = component.querySelector("[data-track]");
    const artworkNode = component.querySelector("[data-artwork]");
    const titleNode = component.querySelector("[data-title]");
    const metaNode = component.querySelector("[data-meta]");

    if (!endpoint || !statusNode || !trackNode || !titleNode || !metaNode) {
      return;
    }

    try {
      const response = await fetch(endpoint, {
        headers: {
          accept: "application/json",
        },
      });

      if (!response.ok) {
        throw new Error(`Spotify request failed (${response.status})`);
      }

      const payload = await response.json();
      const track = payload?.track;

      if (!payload?.ok || !track) {
        statusNode.textContent = "Spotify is currently unavailable.";
        return;
      }

      statusNode.textContent = track.isPlaying
        ? "Currently playing"
        : formatPlayedAt(track.playedAt);

      titleNode.textContent = track.title ?? "Unknown track";
      metaNode.textContent = [track.artists, track.album]
        .filter(Boolean)
        .join(" · ");
      trackNode.href = track.url || "https://open.spotify.com";
      trackNode.hidden = false;

      if (artworkNode && track.artworkUrl) {
        artworkNode.src = track.artworkUrl;
        artworkNode.alt = `${track.album || track.title} artwork`;
        artworkNode.hidden = false;
      }
    } catch (error) {
      console.error(error);
      statusNode.textContent = "Spotify is currently unavailable.";
    }
  }

  components.forEach((component) => {
    hydrateSpotify(component);
  });
</script>
