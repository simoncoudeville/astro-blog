---
const endpoint = "/.netlify/functions/spotify-latest";
---

<div class="spotify" data-endpoint={endpoint}>
  <h2 class="spotify__title" data-status>Loading latest Spotify track&hellip;</h2>

  <article class="spotify__track" hidden data-track>
    
      <a
        class="spotify__track-link"
        href="#"
        rel="noopener noreferrer"
        target="_blank"
        data-track-link
      >
        <div class="spotify__track-image">
          <img
            alt=""
            hidden
            width="50"
            height="50"
            loading="lazy"
            decoding="async"
            data-artwork
          />
        </div>
        <h3 class="spotify__track-title" data-title></h3>
        <p class="spotify__track-meta color-meta" data-meta></p>
      </a>
  </article>
</div>

<script>
  const components = document.querySelectorAll("[data-endpoint]");

  async function hydrateSpotify(component) {
    const endpoint = component.getAttribute("data-endpoint");
    const statusNode = component.querySelector("[data-status]");
    const trackNode = component.querySelector("[data-track]");
    const trackLink = component.querySelector("[data-track-link]");
    const artworkNode = component.querySelector("[data-artwork]");
    const titleNode = component.querySelector("[data-title]");
    const metaNode = component.querySelector("[data-meta]");

    if (
      !endpoint ||
      !statusNode ||
      !trackNode ||
      !trackLink ||
      !titleNode ||
      !metaNode
    ) {
      return;
    }

    try {
      const response = await fetch(endpoint, {
        headers: {
          accept: "application/json",
        },
      });

      if (!response.ok) {
        throw new Error(`Spotify request failed (${response.status})`);
      }

      const payload = await response.json();
      const track = payload?.track;

      if (!payload?.ok || !track) {
        statusNode.textContent = "Spotify is currently unavailable\u2026";
        return;
      }

      statusNode.textContent = track.isPlaying
        ? "Currently playing"
        : "Recently played";

      titleNode.textContent = track.title ?? "Unknown track";
      metaNode.textContent = track.artists ?? "";
      trackLink.href = track.url || "https://open.spotify.com";
      trackNode.hidden = false;

      if (artworkNode && track.artworkUrl) {
        artworkNode.alt = `${track.album || track.title} artwork`;
        if (track.isPlaying) {
          artworkNode.classList.add("spotify__image--playing");
        }
        artworkNode.onload = () => {
          artworkNode.hidden = false;
        };
        artworkNode.src = track.artworkUrl;
      }
    } catch (error) {
      console.error(error);
      statusNode.textContent = "Spotify is currently unavailable\u2026";
    }
  }

  components.forEach((component) => {
    hydrateSpotify(component);
  });
</script>

<style>
  .spotify {
    display: grid;
    gap: var(--global-whitespace-4);
    background: var(--global-foregroundColor);
    border-radius: var(--global-borderRadius-lg);
    padding: var(--global-whitespace-5);
    margin-inline: calc(var(--global-whitespace-5) * -1);
  }

  .spotify__title {
    color: var(--global-meta-color);
    --fs: var(--ms-1);
    font-size: calc(var(--fs) / var(--root-font-size) * 1rem);
    line-height: calc(var(--global-baseline) * 4);
    color: var(--global-meta-color);
    /* margin-bottom: var(--global-whitespace-4); */
  }

  .spotify__track-link {
       display: grid;
    grid-template-columns: auto 1fr;
    grid-template-areas: "image title" "image description";
    gap: 0 var(--global-whitespace-2);
    text-decoration: none;
    /* --fs: var(--ms-1);
    font-size: calc(var(--fs) / var(--root-font-size) * 1rem);
    line-height: calc(var(--global-baseline) * 4); */
  }

  .spotify__track-image {
    grid-area: image;

    img {
      width: var(--global-whitespace-10);
      border-radius: 100%;
    }
  }



  .spotify__image--playing {
    /* animation: turntable 1s ease 0 infinite; */
  animation-name: turntable;
  animation-duration: 1.8s;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  }

  .spotify__track-title {
    grid-area: title;
    color: var(--global-text-color);
  }

  .spotify__track-meta {
    grid-area: description;
    color: var(--global-meta-color);
  }


@keyframes turntable {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
</style>