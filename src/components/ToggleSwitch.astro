---
// Reusable toggle switch. The checkbox itself is the track (styled via
// appearance: none) and its ::before is the sliding thumb. Any extra props
// (checked, data-*, id, name, …) are forwarded to the input, so it stays a
// real form control. Label content comes from the default slot.
//
//   <ToggleSwitch checked data-toggle-grid>Show grid</ToggleSwitch>
const props = Astro.props;
---

<label class="toggle-switch">
  <input type="checkbox" {...props} />
  <span class="toggle-switch__label"><slot /></span>
</label>

<style>
  .toggle-switch {
    --toggle-width: calc(var(--global-whitespace) * 1.75);
    --toggle-height: var(--global-whitespace);
    --toggle-pad: .25rem;

    display: inline-flex;
    align-items: center;
    gap: var(--global-whitespace-2xs);
    cursor: pointer;
  }

  /* Track */
  .toggle-switch input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    box-sizing: border-box;
    flex: none;
    position: relative;
    width: var(--toggle-width);
    height: var(--toggle-height);
    margin: 0;
    border-radius: 999px;
    background: var(--global-foregroundColor2);
    cursor: pointer;
    transition: background var(--global-transition-duration-short) ease;
  }

  /* Thumb: page background (white in light, black in dark) with a 1px border. */
  .toggle-switch input[type="checkbox"]::before {
    content: "";
    position: absolute;
    top: var(--toggle-pad);
    left: var(--toggle-pad);
    box-sizing: border-box;
    width: calc(var(--toggle-height) - var(--toggle-pad) * 2);
    height: calc(var(--toggle-height) - var(--toggle-pad) * 2);
    border-radius: 50%;
    background: var(--global-backgroundColor);
    transition: translate var(--global-transition-duration-short) ease;
  }

  .toggle-switch input[type="checkbox"]:checked {
    background: var(--global-title-color);
  }

  .toggle-switch input[type="checkbox"]:checked::before {
    translate: calc(var(--toggle-width) - var(--toggle-height)) 0;
    border-color: transparent;
  }

  .toggle-switch input[type="checkbox"]:focus-visible {
    outline: 2px solid var(--global-text-color);
    outline-offset: 2px;
  }
</style>
